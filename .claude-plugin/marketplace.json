{
  "name": "avuzskill",
  "owner": {
    "name": "AVuzskill Maintainers"
  },
  "metadata": {
    "description": "Hardened unified skill bundle with one canonical .agent/skills tree",
    "version": "1.1.0"
  },
  "plugins": [
    {
      "name": "core-skills",
      "description": "Routing, implementation, design, testing, and skill-authoring essentials",
      "source": "../.agent",
      "strict": false,
      "skills": [
        "./skills/workspace-operating-system",
        "./skills/frontend-design",
        "./skills/mcp-builder",
        "./skills/webapp-testing",
        "./skills/skill-creator"
